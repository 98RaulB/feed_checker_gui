{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowFeedCheckerRepoMainAudit",
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::620369152593:oidc-provider/token.actions.githubusercontent.com"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
          "token.actions.githubusercontent.com:sub": "repo:98RaulB/feed_checker_gui:ref:refs/heads/main"
        }
      }
    }
  ]
}
